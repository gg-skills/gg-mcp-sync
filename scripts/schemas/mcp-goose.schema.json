{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "mcp-goose.schema.json",
  "title": "Goose CLI MCP Configuration",
  "description": "Schema for Goose CLI configuration (YAML with extensions key). Extensions include both built-in platform extensions and MCP server extensions.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "extensions": {
      "type": "object",
      "description": "Map of extension configurations (platform built-ins and MCP servers)",
      "additionalProperties": {
        "type": "object",
        "description": "Extension configuration",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "description": "Human-readable name for the extension"
          },
          "command": {
            "type": "string",
            "description": "Command to execute (MCP server extensions)"
          },
          "args": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Arguments passed to the command"
          },
          "env": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Environment variables for the server process"
          },
          "timeout": {
            "type": "number",
            "minimum": 0,
            "description": "Extension timeout in seconds"
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether the extension is enabled"
          },
          "type": {
            "type": "string",
            "description": "Extension type (e.g., platform, stdio)"
          }
        }
      }
    }
  }
}
